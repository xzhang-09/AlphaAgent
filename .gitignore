build/
dist/
*.egg-info/

# App runtime storage
storage/cache/*
storage/vector_db/*
storage/exports/*
storage/ideas/*

# Keep storage directories in git
!storage/cache/.gitkeep
!storage/vector_db/.gitkeep
!storage/exports/.gitkeep
!storage/ideas/.gitkeep
