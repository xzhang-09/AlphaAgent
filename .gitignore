# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Virtual environments
.venv/
venv/

# Test and tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Local environment/config
.env

# macOS / editor noise
.DS_Store

